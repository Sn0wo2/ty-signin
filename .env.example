TY_SIGNIN_API_ID=YOUR_TELEGRAM_API_ID
TY_SIGNIN_API_HASH=YOUR_TELEGRAM_API_HASH

# Sign-in task configuration (JSON array)
# Each item requires a session name, target, and message.
TY_SIGNIN_CONFIG='[
  {
    "session": "ty_signin",
    "target": "YOUR_BOT",
    "message": "YOUR_SIGNIN_MESSAGE"
  }
]'

# Persistent data directory for sessions and logs.
# In QingLong, use a path such as /ql/data/ty-sign.
TY_SIGNIN_DATA_DIR=.data

# Optional. Defaults to ${TY_SIGNIN_DATA_DIR}/logs/ty-signin.log.
# TY_SIGNIN_LOG_FILE=.data/logs/ty-signin.log
TY_SIGNIN_TIMEZONE=Asia/Singapore
TY_SIGNIN_REPLY_TIMEOUT=15

# Set temporarily when Telegram 2FA is enabled (QingLong env var only).
# TY_SIGNIN_2FA_PASSWORD=YOUR_TELEGRAM_2FA_PASSWORD
