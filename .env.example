API_ID=YOUR_TELEGRAM_API_ID
API_HASH=YOUR_TELEGRAM_API_HASH

# Sign-in task configuration (JSON array)
# Each item requires a session name, target, and message.
SIGNIN_CONFIG='[
  {
    "session": "ty_signin",
    "target": "YOUR_BOT",
    "message": "YOUR_SIGNIN_MESSAGE"
  }
]'

# Persistent data directory for sessions and logs.
# In QingLong, use a path such as /ql/data/ty-sign.
DATA_DIR=.data

# Optional. Defaults to ${DATA_DIR}/logs/ty-signin.log.
# LOG_FILE=.data/logs/ty-signin.log
TIMEZONE=Asia/Singapore
REPLY_TIMEOUT=15

# Set temporarily for QingLong login tasks when 2FA is enabled.
# TELEGRAM_2FA_PASSWORD=YOUR_TELEGRAM_2FA_PASSWORD
