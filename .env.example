API_ID=your_api_id
API_HASH=your_api_hash

# Configuration for all sign-in tasks (JSON list of objects)
# Each task object supports:
#   "session" : "Custom session name" (Required)
#   "target"  : @name, username, numeric ID, or t.me/ link (Required)
#   "message" : "The sign-in message" (Required)
SIGNIN_CONFIG='[
  {
    "session": "ty_signin",
    "target": "ty_signin_bot",
    "message": "Sign"
  }
]'

# Data directory for session and default log files.
# In QingLong, set this to a persistent path such as /ql/data/ty-sign.
DATA_DIR=.data

# Optional. Defaults to ${DATA_DIR}/logs/ty-signin.log.
# LOG_FILE=.data/logs/ty-signin.log
TIMEZONE=Asia/Shanghai
REPLY_TIMEOUT=15
