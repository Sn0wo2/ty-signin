API_ID=your_api_id
API_HASH=your_api_hash

# Sign-in target(s). Works for bots, users, groups and channels.
# Accepts: @name / name / numeric id (e.g. -1001234567890) / t.me/name
# Multiple targets: separate with commas, e.g. TARGET=@bot1,@group2,123456
TARGET=freexzteam_bot

SIGN_MESSAGE=📅 每日签到
SESSION_NAME=.data/session/ty_sign
LOG_FILE=.data/logs/sign.log
TIMEZONE=Asia/Shanghai
SIGN_TIME=00:00
REPLY_TIMEOUT=15
